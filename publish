#!/bin/sh
# publish — compile paper + poster, commit, and push to github.com/ganddoffcha/quantum-spin
set -eu

REPO="/home/gc/Documents/quantum-spin-public"
TEXINPUTS=".:/home/gc/Documents/texnow//:"

cd "$REPO"

# Compile paper (pdflatex)
echo "=== Compiling paper ==="
cd "$REPO/paper"
TEXINPUTS="$TEXINPUTS" latexmk -g -pdf "Representations_of_Lie_Groups_A_Mathematical_Dissection_of_Quantum.tex"

# Compile poster (lualatex)
echo "=== Compiling poster ==="
cd "$REPO/poster"
TEXINPUTS="$TEXINPUTS" latexmk -g -lualatex poster.tex

# Commit and push
cd "$REPO"
git add -A
if git diff --cached --quiet; then
    echo "Nothing to publish."
else
    git commit -m "Update paper and poster"
    git pull --rebase
    git push
    echo "=== Published → github.com/ganddoffcha/quantum-spin ==="
fi
